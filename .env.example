# ============================================================
# Photo-to-Parable Converter — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Anthropic API key for Claude vision-based extraction.
# Required. Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the server port (default: 3000)
# PORT=3000

# ============================================================
# Setup Instructions
# ============================================================
# 1. cp .env.example .env
# 2. Set ANTHROPIC_API_KEY in .env
# 3. npm install
# 4. npm start
# 5. Open http://localhost:3000
# 6. Navigate to http://localhost:3000/photo-converter.html

# ============================================================
# Upload Limits
# ============================================================
# Max files per request : 5
# Max size per file     : 10 MB
# Supported types       : image/jpeg, image/png, image/webp
